# ============================================================
# ViralStack — Short-form Automation
# ============================================================
# HOW TO USE:
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in your values following the guide below
# 3. Never commit .env to git (it's already in .gitignore)
# ============================================================


# ============================================================
# LANGUAGE
# ============================================================
# "es" = Spanish (prompts, TTS voice, hashtags, emails — everything)
# "en" = English
LANGUAGE=es


# ============================================================
# DISCORD BOT  (optional — for remote control & alerts)
# ============================================================
# HOW TO GET:
# 1. Go to https://discord.com/developers/applications
# 2. Click "New Application" → give it a name
# 3. Go to "Bot" → click "Reset Token" → copy the token
# 4. Enable "Message Content Intent" under Privileged Gateway Intents
# 5. Go to OAuth2 → URL Generator → select "bot" + "applications.commands"
# 6. Open the generated URL in your browser to invite the bot to your server
#
# HOW TO GET CHANNEL & SERVER IDs:
# Enable Developer Mode in Discord (Settings → Advanced → Developer Mode)
# Right-click your server → "Copy Server ID"
# Right-click a channel → "Copy Channel ID"
# Right-click your username → "Copy User ID"

DISCORD_BOT_TOKEN=              # Paste your bot token here
DISCORD_GUILD_ID=               # Your Discord server ID
DISCORD_OWNER_ID=               # Your Discord user ID (only you can run commands)
DISCORD_ALERTS_CHANNEL_ID=      # Channel for error/success alerts
DISCORD_STATS_CHANNEL_ID=       # Channel for daily stats reports

# Optional legacy webhook (leave as-is if using the bot above)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN


# ============================================================
# VERTEX AI  (required — main AI engine)
# ============================================================
# HOW TO GET:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or select an existing one)
# 3. Enable "Vertex AI API":
#    APIs & Services → Enable APIs → search "Vertex AI API" → Enable
# 4. Create an API key:
#    APIs & Services → Credentials → Create Credentials → API Key
# 5. Copy the key and paste it below
#
# NOTE: Vertex AI is pay-as-you-go. Typical cost: $0.50–$3 per day for 6 videos.
# New Google Cloud accounts get $300 free credit.

VERTEX_AI_API_KEY=              # Paste your Vertex AI API key here (starts with AQ.)
VERTEX_AI_PROJECT=              # Leave empty when using an API key (not needed)
VERTEX_AI_LOCATION=us-central1  # Region — us-central1 works for all models

# Gemini models tried in order (first = primary, last = last resort)
# You can remove models you don't have access to
GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-2.5-pro,gemini-2.5-flash

# Optional: extra Gemini API keys for rotation (Vertex AI key works too via VERTEX_AI_API_KEY).
# Comma-separated. Falls back to VERTEX_AI_API_KEY if empty.
GEMINI_API_KEYS=


# ============================================================
# GOOGLE AI  (optional — used for video quality check)
# ============================================================
# Free API key at https://aistudio.google.com/apikey
# If not set, quality check is skipped and all videos are auto-approved.
GOOGLE_AI_API_KEY=              # Free key from Google AI Studio

# ============================================================
# ELEVENLABS  (optional — premium TTS fallback)
# ============================================================
# Only needed if you want ElevenLabs voices as TTS fallback.
# The system already uses Gemini TTS (primary) and Edge TTS (free fallback).
# Get keys at https://elevenlabs.io → Profile → API Keys
# You can add multiple keys separated by commas for rotation.
ELEVENLABS_API_KEYS=            # key1,key2,key3 (or leave empty)


# ============================================================
# GOOGLE DRIVE BACKUP  (optional — auto-backup videos to Drive)
# ============================================================
# HOW TO GET a Service Account:
# 1. Go to https://console.cloud.google.com → your project
# 2. IAM & Admin → Service Accounts → Create Service Account
# 3. Give it a name (e.g. "tiktok-automation")
# 4. Grant role: "Editor" or just "Drive File Creator"
# 5. Click the service account → Keys → Add Key → JSON → Download
# 6. Rename the downloaded file to service_account.json
# 7. Place it in the config/ folder: config/service_account.json
# 8. Also enable "Google Drive API" in APIs & Services
GOOGLE_SERVICE_ACCOUNT_FILE=config/service_account.json


# ============================================================
# YOUTUBE OAUTH  (optional — to publish YouTube Shorts)
# ============================================================
# HOW TO GET:
# 1. Go to https://console.cloud.google.com → your project
# 2. Enable "YouTube Data API v3":
#    APIs & Services → Enable APIs → search "YouTube Data API v3" → Enable
# 3. Create OAuth credentials:
#    APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client IDs
#    Application type: Desktop app → Create
# 4. Copy Client ID and Client Secret below
# 5. Run setup script for each account:
#    python scripts/setup_youtube.py terror
#    python scripts/setup_youtube.py historias
#    python scripts/setup_youtube.py dinero
#    (A browser will open — log in with the correct Google account)
# 6. Token files are saved automatically to config/

YOUTUBE_CLIENT_ID=              # OAuth 2.0 Client ID (ends in .apps.googleusercontent.com)
YOUTUBE_CLIENT_SECRET=          # OAuth 2.0 Client Secret (starts with GOCSPX-)
YOUTUBE_TERROR_TOKEN=config/youtube_terror_token.json      # Auto-generated by setup script
YOUTUBE_HISTORIAS_TOKEN=config/youtube_historias_token.json # Auto-generated by setup script
YOUTUBE_DINERO_TOKEN=config/youtube_dinero_token.json       # Auto-generated by setup script


# ============================================================
# GMAIL OAUTH  (optional — auto-reply to sponsor/fan emails)
# ============================================================
# Uses the SAME OAuth credentials as YouTube above.
# After setting up YouTube OAuth, run:
#   python scripts/setup_gmail.py terror
#   python scripts/setup_gmail.py historias
#   python scripts/setup_gmail.py dinero
# (Also enable "Gmail API" in APIs & Services → Enable APIs)

GMAIL_CLIENT_ID=                # Same as YOUTUBE_CLIENT_ID (reuse the same app)
GMAIL_CLIENT_SECRET=            # Same as YOUTUBE_CLIENT_SECRET
GMAIL_TERROR_TOKEN=config/gmail_terror_token.json       # Auto-generated by setup script
GMAIL_HISTORIAS_TOKEN=config/gmail_historias_token.json # Auto-generated by setup script
GMAIL_DINERO_TOKEN=config/gmail_dinero_token.json       # Auto-generated by setup script


# ============================================================
# TIKTOK COOKIES  (optional — to publish to TikTok)
# ============================================================
# HOW TO GET:
# 1. Install the browser extension "Get cookies.txt LOCALLY" in Chrome/Firefox
# 2. Log in to TikTok in your browser (for each account)
# 3. Go to tiktok.com, click the extension → Export cookies as Netscape format
# 4. Save each file to storage/cookies/:
#    storage/cookies/terror_cookies.txt
#    storage/cookies/historias_cookies.txt
#    storage/cookies/dinero_cookies.txt
# OR run: python scripts/export_cookies.py (automated extraction)
#
# NOTE: Cookies expire after ~2 months. Re-export when TikTok uploads stop working.

TIKTOK_TERROR_COOKIES=storage/cookies/terror_cookies.txt
TIKTOK_HISTORIAS_COOKIES=storage/cookies/historias_cookies.txt
TIKTOK_DINERO_COOKIES=storage/cookies/dinero_cookies.txt


# ============================================================
# GENERIC / WEBHOOK PLATFORMS  (NEW in v1.2)
# ============================================================
# Platforms are registered in config/platform_registry.json.
# TikTok and YouTube are built in. Instagram Reels is available through
# a webhook automation (Make/Zapier/n8n/custom API) and is OFF by default
# in config/platforms.json until you enable it per account.

INSTAGRAM_WEBHOOK_URL=          # Optional: endpoint that receives multipart video uploads
PLATFORM_WEBHOOK_TIMEOUT_SECONDS=120


# ============================================================
# VIDEO PRODUCTION SETTINGS
# ============================================================
# How many videos per day per account (0 = disabled, max 6)
VIDEOS_PER_DAY_TERROR=2
VIDEOS_PER_DAY_HISTORIAS=2
VIDEOS_PER_DAY_DINERO=2

# For additional accounts, copy config/accounts.example.json to config/accounts.json.
# Per-account videos_per_day, prompt_file, hashtags, quality_threshold, paths, and
# platform toggles live there so you do not need to edit Python code.


# ============================================================
# GENERAL SETTINGS
# ============================================================
DB_PATH=storage/viralstack.db
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
QUALITY_THRESHOLD=6.0           # Minimum quality score (0-10) to publish a video
MAX_RETRIES_PER_VIDEO=3         # How many times to retry if quality check fails
WHISPER_MODEL=base              # Whisper model size: tiny, base, small, medium, large


# ============================================================
# FFMPEG PATH
# ============================================================
# On Linux/Mac/VPS: just use "ffmpeg" (installed via package manager)
# On Windows: use the full path to ffmpeg.exe
#   Download from: https://github.com/BtbN/FFmpeg-Builds/releases
#   Extract and set the path below, e.g.:
#   FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
# The setup script can install it automatically: python scripts/setup_ffmpeg.py
FFMPEG_PATH=ffmpeg


# ============================================================
# VIDEO QUALITY SETTINGS
# ============================================================
# CRF: lower = better quality but larger file size
#   18 = high quality (~80MB), 20 = good quality (~50MB), 23 = default, 28 = small
VIDEO_CRF=20
VIDEO_PRESET=medium             # Encoding speed: ultrafast, fast, medium, slow
VIDEO_BITRATE_AUDIO=192k        # Audio bitrate (128k = smaller, 192k = better quality)
VIDEO_WIDTH=1080                # Keep at 1080x1920 for TikTok/Shorts vertical format
VIDEO_HEIGHT=1920


# ============================================================
# SCHEDULING & DASHBOARD
# ============================================================
# Timezone for video scheduling. Examples:
#   America/New_York, America/Mexico_City, America/Los_Angeles
#   Europe/Madrid, Europe/London, Asia/Tokyo
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/New_York

DASHBOARD_HOST=0.0.0.0          # Use 0.0.0.0 to access from other devices on the network
DASHBOARD_PORT=8000             # Dashboard available at http://localhost:8000


# ============================================================
# MULTI-LLM SCRIPT GENERATION  (NEW in v1.1)
# ============================================================
# Scripts can now be generated with any of these providers, in fallback order.
# The first available provider with a non-empty result wins.
# Pegá una clave (o varias separadas por coma) en el(los) proveedor(es) que quieras usar.
# Si dejás todo vacío excepto Gemini, el sistema funciona como antes.
SCRIPT_PROVIDER_CHAIN=gemini,openai,anthropic,openrouter,groq,deepseek,together,mistral,ollama

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEYS=
OPENAI_MODELS=gpt-5.4,gpt-5.4-mini,gpt-5.4-nano

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEYS=
ANTHROPIC_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5

# OpenRouter (acceso unificado a 100+ modelos) — https://openrouter.ai/keys
OPENROUTER_API_KEYS=
OPENROUTER_MODELS=openai/gpt-5.4,anthropic/claude-opus-4.7,anthropic/claude-sonnet-4.6,google/gemini-3.1-pro-preview,google/gemini-3-flash-preview,deepseek/deepseek-chat

# Groq (ultra rápido, free tier generoso) — https://console.groq.com/keys
GROQ_API_KEYS=
GROQ_MODELS=openai/gpt-oss-120b,openai/gpt-oss-20b,llama-3.3-70b-versatile,llama-3.1-8b-instant,groq/compound-mini

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEYS=
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# Together AI — https://api.together.ai/settings/api-keys
TOGETHER_API_KEYS=
TOGETHER_MODELS=meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8,meta-llama/Llama-4-Scout-17B-16E-Instruct,deepseek-ai/DeepSeek-V3.1,Qwen/Qwen3-Next-80B-A3B-Instruct,moonshotai/Kimi-K2-Instruct

# Mistral — https://console.mistral.ai/api-keys/
MISTRAL_API_KEYS=
MISTRAL_MODELS=mistral-medium-2508,mistral-large-latest,mistral-small-latest,devstral-medium-latest,codestral-latest

# Ollama (local, sin coste, sin clave) — https://ollama.com/
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=qwen3:latest,qwen3:30b,qwen3:235b,qwen3-vl:8b,qwen3-coder-next,llama3.3,gpt-oss:20b


# ============================================================
# DASHBOARD AUTH  (optional — set to enable X-API-Key on /api/*)
# ============================================================
# If empty, the dashboard is open. Set a long random string to require it
# in the X-API-Key header (the UI input persists it in localStorage).
DASHBOARD_API_KEY=
